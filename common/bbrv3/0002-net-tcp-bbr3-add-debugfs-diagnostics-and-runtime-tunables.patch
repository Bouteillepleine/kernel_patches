From 84de740463b4939d502ccf7a47c195fd32427624 Mon Sep 17 00:00:00 2001
From: fatalcoder524 <11532648+fatalcoder524@users.noreply.github.com>
Date: Sun, 12 Jul 2026 00:00:00 +0000
Subject: [PATCH] net: tcp: bbr3: add debugfs diagnostics and runtime tunables
 (v2)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Additive follow-up to the BBRv3 backport; no frozen KMI type is
touched and — unlike v1 — no per-connection hot-path code is added.

1) /sys/kernel/debug/tcp_bbr3/sockets: one line per live bbr3
   connection (ports, mode, bw_hi/lo, inflight_hi/lo, min_rtt_us,
   ecn_alpha, gains, full_bw_reached). Implemented as a read-time
   RCU walk of the TCP established hash (the /proc/net/tcp pattern):
   no socket registry, no bbr3_init()/bbr3_release() changes, no
   shared mutable state. v1 used a spinlock-protected registry
   published from bbr3_init(); that build failed to boot on the
   OnePlus 15 (mechanism undetermined; bisected to exactly those
   hooks) — this rewrite removes the entire class.

2) Runtime tunables under /sys/module/tcp_bbr3/parameters/ (0644):
   bbr_min_rtt_win_sec, bbr_probe_rtt_mode_ms, bbr_probe_rtt_win_ms,
   bbr_ecn_max_rtt_us, bbr_ecn_factor, bbr_ecn_thresh,
   bbr_loss_thresh, bbr_full_loss_cnt. Fractions are BBR_UNIT=256
   scaled where noted.

3) Mobile ECN enablement: BBRv3's ECN logic ships with datacenter
   tuning (bbr_ecn_max_rtt_us=5000 makes it ineligible at mobile
   RTTs). To experiment on ECN-marking networks:
     echo 0 > /sys/module/tcp_bbr3/parameters/bbr_ecn_max_rtt_us
     sysctl -w net.ipv4.tcp_ecn=1
   and set RTAX_FEATURE_ECN_LOW (1<<5) on the route via netlink.

4) Build tcp_bbr3.o with -Os (CFLAGS_tcp_bbr3.o += -Os). The BBRv3
   object's built-in size pushed the vmlinux Image just past the
   OnePlus 15 recovery boot-image size limit (0x2700000 = 39 MiB),
   which overlaps the larger recovery ramdisk and cold-resets before
   the logo. Size-compiling only tcp_bbr3.o reclaims enough to clear
   the boundary while keeping every feature config and leaving the
   rest of the kernel at -O2.
---
 net/ipv4/Makefile   |  1 +
 net/ipv4/tcp_bbr3.c | 98 ++++++++++++++++++++++++++++++++++++++++-----
 2 files changed, 89 insertions(+), 10 deletions(-)

diff --git a/net/ipv4/Makefile b/net/ipv4/Makefile
index 45324da..cb73741 100644
--- a/net/ipv4/Makefile
+++ b/net/ipv4/Makefile
@@ -46,6 +46,7 @@ obj-$(CONFIG_INET_UDP_DIAG) += udp_diag.o
 obj-$(CONFIG_INET_RAW_DIAG) += raw_diag.o
 obj-$(CONFIG_TCP_CONG_BBR) += tcp_bbr.o
 obj-$(CONFIG_TCP_CONG_BBR3) += tcp_bbr3.o
+CFLAGS_tcp_bbr3.o += -Os
 obj-$(CONFIG_TCP_CONG_BIC) += tcp_bic.o
 obj-$(CONFIG_TCP_CONG_CDG) += tcp_cdg.o
 obj-$(CONFIG_TCP_CONG_CUBIC) += tcp_cubic.o
diff --git a/net/ipv4/tcp_bbr3.c b/net/ipv4/tcp_bbr3.c
index 84ff858..3758189 100644
--- a/net/ipv4/tcp_bbr3.c
+++ b/net/ipv4/tcp_bbr3.c
@@ -64,6 +64,8 @@
 #include <linux/inet.h>
 #include <linux/random.h>
 #include <linux/win_minmax.h>
+#include <linux/debugfs.h>
+#include <linux/seq_file.h>
 
 #include <trace/events/tcp.h>
 #include "tcp_dctcp.h"
@@ -106,14 +108,20 @@ struct bbr_context {
 };
 
 /* Window length of min_rtt filter (in sec): */
-static const u32 bbr_min_rtt_win_sec = 10;
+static u32 bbr_min_rtt_win_sec __read_mostly = 10;
+module_param(bbr_min_rtt_win_sec, uint, 0644);
+MODULE_PARM_DESC(bbr_min_rtt_win_sec, "min_rtt filter window (sec)");
 /* Minimum time (in ms) spent at bbr_cwnd_min_target in BBR_PROBE_RTT mode: */
-static const u32 bbr_probe_rtt_mode_ms = 200;
+static u32 bbr_probe_rtt_mode_ms __read_mostly = 200;
+module_param(bbr_probe_rtt_mode_ms, uint, 0644);
+MODULE_PARM_DESC(bbr_probe_rtt_mode_ms, "min time at cwnd_min_target in PROBE_RTT (ms)");
 /* Window length of probe_rtt_min_us filter (in ms), and consequently the
  * typical interval between PROBE_RTT mode entries. The default is 5000ms.
  * Note that bbr_probe_rtt_win_ms must be <= bbr_min_rtt_win_sec * MSEC_PER_SEC
  */
-static const u32 bbr_probe_rtt_win_ms = 5000;
+static u32 bbr_probe_rtt_win_ms __read_mostly = 5000;
+module_param(bbr_probe_rtt_win_ms, uint, 0644);
+MODULE_PARM_DESC(bbr_probe_rtt_win_ms, "probe_rtt_min filter window / PROBE_RTT interval (ms)");
 /* Proportion of cwnd to estimated BDP in PROBE_RTT, in units of BBR_UNIT: */
 static const u32 bbr_probe_rtt_cwnd_gain = BBR_UNIT * 1 / 2;
 
@@ -189,7 +197,9 @@ static const bool bbr_precise_ece_ack = true;
 /* Max RTT (in usec) at which to use sender-side ECN logic.
  * Disabled when 0 (ECN allowed at any RTT).
  */
-static const u32 bbr_ecn_max_rtt_us = 5000;
+static u32 bbr_ecn_max_rtt_us __read_mostly = 5000;
+module_param(bbr_ecn_max_rtt_us, uint, 0644);
+MODULE_PARM_DESC(bbr_ecn_max_rtt_us, "max RTT (us) for sender-side ECN logic; 0 = any RTT");
 
 /* On losses, scale down inflight and pacing rate by beta scaled by BBR_SCALE.
  * No loss response when 0.
@@ -207,12 +217,16 @@ static const u32 bbr_ecn_alpha_init = BBR_UNIT;
 /* On ECN, cut inflight_lo to (1 - ecn_factor * ecn_alpha) scaled by BBR_SCALE.
  * No ECN based bounding when 0.
  */
-static const u32 bbr_ecn_factor = BBR_UNIT * 1 / 3;	 /* 1/3 = 33% */
+static u32 bbr_ecn_factor __read_mostly = BBR_UNIT * 1 / 3;	 /* 1/3 = 33% */
+module_param(bbr_ecn_factor, uint, 0644);
+MODULE_PARM_DESC(bbr_ecn_factor, "ECN inflight_lo cut factor (BBR_UNIT=256 fraction); 0 = off");
 
 /* Estimate bw probing has gone too far if CE ratio exceeds this threshold.
  * Scaled by BBR_SCALE. Disabled when 0.
  */
-static const u32 bbr_ecn_thresh = BBR_UNIT * 1 / 2;  /* 1/2 = 50% */
+static u32 bbr_ecn_thresh __read_mostly = BBR_UNIT * 1 / 2;  /* 1/2 = 50% */
+module_param(bbr_ecn_thresh, uint, 0644);
+MODULE_PARM_DESC(bbr_ecn_thresh, "CE ratio probe-too-far threshold (BBR_UNIT=256 fraction); 0 = off");
 
 /* If non-zero, if in a cycle with no losses but some ECN marks, after ECN
  * clears then make the first round's increment to inflight_hi the following
@@ -221,7 +235,9 @@ static const u32 bbr_ecn_thresh = BBR_UNIT * 1 / 2;  /* 1/2 = 50% */
 static const u32 bbr_ecn_reprobe_gain = BBR_UNIT * 1 / 2;
 
 /* Estimate bw probing has gone too far if loss rate exceeds this level. */
-static const u32 bbr_loss_thresh = BBR_UNIT * 2 / 100;  /* 2% loss */
+static u32 bbr_loss_thresh __read_mostly = BBR_UNIT * 2 / 100;  /* 2% loss */
+module_param(bbr_loss_thresh, uint, 0644);
+MODULE_PARM_DESC(bbr_loss_thresh, "loss-rate probe-too-far threshold (BBR_UNIT=256 fraction)");
 
 /* Slow down for a packet loss recovered by TLP? */
 static const bool bbr_loss_probe_recovery = true;
@@ -230,7 +246,9 @@ static const bool bbr_loss_probe_recovery = true;
  * and loss rate is higher than bbr_loss_thresh.
  * Disabled if 0.
  */
-static const u32 bbr_full_loss_cnt = 6;
+static u32 bbr_full_loss_cnt __read_mostly = 6;
+module_param(bbr_full_loss_cnt, uint, 0644);
+MODULE_PARM_DESC(bbr_full_loss_cnt, "STARTUP exit: loss events per Recovery round; 0 = off");
 
 /* Exit STARTUP if number of round trips with ECN mark rate above ecn_thresh
  * meets this count.
@@ -2019,6 +2037,55 @@ out:
 
 static struct kmem_cache *bbr3_cache __read_mostly;
 
+/* debugfs introspection: read-time walk of the TCP established hash
+ * (the /proc/net/tcp pattern). No per-socket bookkeeping, no shared
+ * mutable state, nothing on any connection hot path. Racy lock-free
+ * field reads, same as inet_diag - fine for diagnostics.
+ */
+static struct dentry *bbr3_debugfs_dir;
+static struct tcp_congestion_ops tcp_bbr3_cong_ops __read_mostly;
+
+static int bbr3_dbg_show(struct seq_file *m, void *v)
+{
+	unsigned int slot;
+
+	seq_puts(m, "# sport dport mode bw_hi0 bw_hi1 bw_lo inflight_hi inflight_lo min_rtt_us ecn_alpha pacing_gain cwnd_gain full_bw_reached\n");
+	seq_puts(m, "# bw unit: packets/uS << 24; gains: BBR_UNIT=256 fractions; ~0 = unset\n");
+	for (slot = 0; slot <= tcp_hashinfo.ehash_mask; slot++) {
+		struct inet_ehash_bucket *head = &tcp_hashinfo.ehash[slot];
+		struct hlist_nulls_node *node;
+		struct sock *sk;
+
+		if (hlist_nulls_empty(&head->chain))
+			continue;
+		rcu_read_lock();
+		sk_nulls_for_each_rcu(sk, node, &head->chain) {
+			const struct inet_sock *inet;
+			const struct bbr3 *bbr;
+
+			if (!sk_fullsock(sk))
+				continue;	/* skip timewait/request socks */
+			if (inet_csk(sk)->icsk_ca_ops != &tcp_bbr3_cong_ops)
+				continue;
+			bbr = *(struct bbr3 **)inet_csk_ca(sk);
+			if (!bbr || !bbr->initialized)
+				continue;
+			inet = inet_sk(sk);
+			seq_printf(m, "%u %u %u %u %u %u %u %u %u %u %u %u %u\n",
+				   ntohs(inet->inet_sport), ntohs(inet->inet_dport),
+				   (u32)bbr->mode,
+				   bbr->bw_hi[0], bbr->bw_hi[1], bbr->bw_lo,
+				   bbr->inflight_hi, bbr->inflight_lo,
+				   bbr->min_rtt_us, (u32)bbr->ecn_alpha,
+				   (u32)bbr->pacing_gain, (u32)bbr->cwnd_gain,
+				   (u32)bbr->full_bw_reached);
+		}
+		rcu_read_unlock();
+	}
+	return 0;
+}
+DEFINE_SHOW_ATTRIBUTE(bbr3_dbg);
+
 static void bbr3_init(struct sock *sk)
 {
 	struct tcp_sock *tp = tcp_sk(sk);
@@ -2115,6 +2182,7 @@ static void bbr3_init(struct sock *sk)
 
 	if (bbr_can_use_ecn(sk))
 		tp->ecn_flags |= TCP_ECN_ECT_PERMANENT;
+
 }
 
 static void bbr3_release(struct sock *sk)
@@ -2347,13 +2415,23 @@ static int __init bbr3_register(void)
 		return -ENOMEM;
 
 	ret = tcp_register_congestion_control(&tcp_bbr3_cong_ops);
-	if (ret)
+	if (ret) {
 		kmem_cache_destroy(bbr3_cache);
-	return ret;
+		return ret;
+	}
+
+	bbr3_debugfs_dir = debugfs_create_dir("tcp_bbr3", NULL);
+	debugfs_create_file("sockets", 0400, bbr3_debugfs_dir, NULL,
+			    &bbr3_dbg_fops);
+	return 0;
 }
 
 static void __exit bbr3_unregister(void)
 {
+	/* .owner pins the module while any socket uses bbr3, so the
+	 * registry is empty by the time we can get here.
+	 */
+	debugfs_remove_recursive(bbr3_debugfs_dir);
 	tcp_unregister_congestion_control(&tcp_bbr3_cong_ops);
 	kmem_cache_destroy(bbr3_cache);
 }
-- 
2.54.0.windows.1

