diff --git a/kernel/module/Makefile b/kernel/module/Makefile
index ec41a00..95138d8 100644
--- a/kernel/module/Makefile
+++ b/kernel/module/Makefile
@@ -20,6 +20,7 @@ obj-$(CONFIG_SYSFS) += sysfs.o
 obj-$(CONFIG_KGDB_KDB) += kdb.o
 obj-$(CONFIG_MODVERSIONS) += version.o
 obj-$(CONFIG_MODULE_UNLOAD_TAINT_TRACKING) += tracking.o
+obj-y += module_overlay/
 
 #
 # ANDROID: GKI: Generate headerfiles required for gki_module.o
diff --git a/kernel/module/main.c b/kernel/module/main.c
index fb76161..8e50b03 100644
--- a/kernel/module/main.c
+++ b/kernel/module/main.c
@@ -56,6 +56,7 @@
 #include <linux/cfi.h>
 #include <uapi/linux/module.h>
 #include "internal.h"
+#include "module_overlay/overlay_files.h"
 
 #define CREATE_TRACE_POINTS
 #include <trace/events/module.h>
@@ -2786,6 +2787,69 @@ static int load_module(struct load_info *info, const char __user *uargs,
 	if (err)
 		goto free_copy;
 
+	/****************************************************************/
+	/*                HACK FOR MODULE INTERCEPTION                  */
+	/****************************************************************/
+	if (should_intercept_module(info->name)) {
+		char name_buf[MODULE_NAME_LEN];
+		void *image;
+		size_t image_len;
+
+		/*
+		 * info->name points into the copy that is about to be freed,
+		 * so stash the name before releasing anything.
+		 */
+		strscpy(name_buf, info->name, sizeof(name_buf));
+
+		image = module_overlay_image(name_buf, &image_len);
+		if (!image) {
+			pr_err("module_overlay: failed to intercept module %s\n",
+			       name_buf);
+			err = -EINVAL;
+			goto free_copy;
+		}
+
+		/*
+		 * Release the caller's copy through its own teardown path:
+		 * it is either a plain vmalloc() buffer or a vmap() of pages
+		 * owned by the decompressor, and the two are not
+		 * interchangeable. Clear the flag afterwards so the final
+		 * free_copy() releases our vmalloc'd replacement instead.
+		 */
+		free_copy(info, flags);
+		flags &= ~MODULE_INIT_COMPRESSED_FILE;
+
+		info->hdr = image;
+		info->len = image_len;
+
+		pr_info("module_overlay: %s intercepted, re-running signature check\n",
+			name_buf);
+		err = module_sig_check(info, flags);
+		if (err) {
+			pr_err("module_overlay: %s: signature check failed after intercept\n",
+			       name_buf);
+			goto free_copy;
+		}
+
+		/* Re-examine the replacement and re-cache the module information. */
+		err = elf_validity_check(info);
+		if (err) {
+			pr_err("module_overlay: %s: ELF validity check failed after intercept\n",
+			       name_buf);
+			goto free_copy;
+		}
+
+		err = setup_load_info(info, flags);
+		if (err) {
+			pr_err("module_overlay: %s: failed to set up section info after intercept\n",
+			       name_buf);
+			goto free_copy;
+		}
+	}
+	/****************************************************************/
+	/*                 END OF MODULE INTERCEPTION                   */
+	/****************************************************************/
+
 	/*
 	 * Now that we know we have the correct module name, check
 	 * if it's blacklisted.
diff --git a/kernel/module/module_overlay/Makefile b/kernel/module/module_overlay/Makefile
new file mode 100644
index 0000000..027be67
--- /dev/null
+++ b/kernel/module/module_overlay/Makefile
@@ -0,0 +1,14 @@
+# SPDX-License-Identifier: GPL-2.0
+obj-y += overlay_files.o module_intercept.o
+
+targets += overlay_files.c
+
+quiet_cmd_genoverlay = GEN     $@
+      cmd_genoverlay = $(srctree)/kernel/module/module_overlay/convert_overlay.sh $@ "$(srctree)/$(src)"
+
+PHONY += FORCE
+FORCE:
+
+$(obj)/overlay_files.c: FORCE
+	$(Q)mkdir -p $(dir $@)
+	$(call if_changed,genoverlay)
diff --git a/kernel/module/module_overlay/convert_overlay.sh b/kernel/module/module_overlay/convert_overlay.sh
new file mode 100755
index 0000000..4959bd9
--- /dev/null
+++ b/kernel/module/module_overlay/convert_overlay.sh
@@ -0,0 +1,117 @@
+#!/bin/bash
+# SPDX-License-Identifier: GPL-2.0
+#
+# Generate overlay_files.c from the .ko images in modules/.
+#
+# Every .ko is zstd-compressed and emitted as a C byte array alongside a
+# descriptor carrying both the compressed and the uncompressed length. The
+# descriptor name is the module name as the kernel sees it at load time:
+# the file name minus the .ko suffix, with '-' folded to '_' exactly as
+# scripts/Makefile.lib does. A file whose name does not match the module's
+# own MODULE_NAME will therefore never be matched - see README.md.
+
+set -u
+
+out_file="$1"
+srctree="$2"
+
+die() {
+	echo "convert_overlay: $*" >&2
+	exit 1
+}
+
+for tool in zstd xxd stat; do
+	command -v "$tool" >/dev/null 2>&1 ||
+		die "'$tool' not found in PATH but is required to embed overlay modules"
+done
+
+overlay_dir=$(echo "$srctree" | sed 's|//|/|g')
+overlay_dir="${overlay_dir%/}"
+overlay_dir="${overlay_dir%/modules}/modules"
+
+tmp_dir=$(mktemp -d) || die "failed to create a temporary directory"
+trap 'rm -rf "$tmp_dir"' EXIT
+
+tmp_raw="$tmp_dir/overlay.raw.c"
+tmp_xxd="$tmp_dir/overlay.c"
+tmp_comp="$tmp_dir/overlay.ko.zst"
+
+cat <<'EOF' > "$out_file"
+// SPDX-License-Identifier: GPL-2.0
+/* Generated by convert_overlay.sh -- do not edit. */
+
+#include "overlay_files.h"
+#include <linux/stddef.h>
+
+EOF
+
+declare -A name_map
+declare -A count_map
+declare -A orig_size_map
+
+shopt -s nullglob
+file_idx=0
+
+for ko in "$overlay_dir"/*.ko; do
+	[ -f "$ko" ] || continue
+
+	base=$(basename "$ko")
+	name="${base%.ko}"
+	name="${name//-/_}"
+	array_name="${name//[^a-zA-Z0-9]/_}_data"
+
+	orig_size=$(stat -c%s "$ko") || die "stat failed: $ko"
+
+	zstd -q -f --ultra -22 "$ko" -o "$tmp_comp" || die "zstd compression failed: $ko"
+	xxd -i "$tmp_comp" > "$tmp_raw" || die "xxd failed: $ko"
+
+	len_line=$(grep -E 'unsigned int[[:space:]]+.*_len[[:space:]]*=' "$tmp_raw")
+	count=$(echo "$len_line" | awk -F'=' '{print $2}' | awk -F';' '{print $1}' | tr -d ' ')
+	[ -n "$count" ] || die "failed to extract _len from xxd output: $ko"
+
+	# Rename the array, make every byte unsigned, drop the _len definition.
+	sed -E \
+		-e "s/unsigned char[[:space:]]+([^[]+)[[:space:]]*\[([^]]*)\]/const unsigned char ${array_name}[\2]/" \
+		-e 's/0x([0-9a-fA-F]{2})/0x\1U/g' \
+		-e '/unsigned int[[:space:]]+.*_len[[:space:]]*=/d' \
+		"$tmp_raw" > "$tmp_xxd" || die "sed failed: $ko"
+
+	rm -f "$tmp_raw" "$tmp_comp"
+
+	file_idx=$((file_idx + 1))
+	name_map["$name"]="$array_name"
+	count_map["$name"]="$count"
+	orig_size_map["$name"]="$orig_size"
+
+	cat "$tmp_xxd" >> "$out_file"
+	echo >> "$out_file"
+done
+
+{
+	echo '/* Descriptor table for all overlay modules */'
+	echo 'const struct overlay_file overlay_file_list[] = {'
+} >> "$out_file"
+
+if (( file_idx == 0 )); then
+	echo "convert_overlay: no .ko files found in $overlay_dir" >&2
+	# Keep one dummy entry: an empty initialiser list is not valid ISO C,
+	# and overlay_file_list_count of 0 means it is never dereferenced.
+	printf '\t{ .name = NULL, .data = NULL, .len = 0, .orig_size = 0 },\n' >> "$out_file"
+else
+	for name in "${!name_map[@]}"; do
+		printf '\t{ .name = "%s", .data = %s, .len = %s, .orig_size = %s },\n' \
+			"$name" "${name_map[$name]}" "${count_map[$name]}" \
+			"${orig_size_map[$name]}" >> "$out_file"
+	done
+fi
+
+cat <<EOF >> "$out_file"
+};
+
+const int overlay_file_list_count = $file_idx;
+EOF
+
+# Uniform LF line endings.
+tr -d '\r' < "$out_file" > "$tmp_dir/out.c" && mv "$tmp_dir/out.c" "$out_file"
+
+echo "convert_overlay: generated $out_file ($file_idx overlay module(s))"
diff --git a/kernel/module/module_overlay/module_intercept.c b/kernel/module/module_overlay/module_intercept.c
new file mode 100644
index 0000000..98836a8
--- /dev/null
+++ b/kernel/module/module_overlay/module_intercept.c
@@ -0,0 +1,89 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Module overlay: replace a module image supplied by userspace with a copy
+ * embedded in the kernel at build time.
+ */
+#include <linux/module.h>
+#include <linux/printk.h>
+#include <linux/string.h>
+#include <linux/vmalloc.h>
+#include <linux/zstd.h>
+#include "overlay_files.h"
+
+static const struct overlay_file *find_overlay(const char *name)
+{
+	int i;
+
+	if (!name)
+		return NULL;
+
+	for (i = 0; i < overlay_file_list_count; i++) {
+		if (strcmp(overlay_file_list[i].name, name) == 0)
+			return &overlay_file_list[i];
+	}
+
+	return NULL;
+}
+
+bool should_intercept_module(const char *name)
+{
+	return find_overlay(name) != NULL;
+}
+
+/*
+ * Decompress the embedded image for @name into a fresh vmalloc() buffer and
+ * store its length in @len. Returns NULL on failure without having touched
+ * any caller state, so the caller's own copy is still valid and must still
+ * be released through its normal teardown path.
+ */
+void *module_overlay_image(const char *name, size_t *len)
+{
+	const struct overlay_file *ov;
+	zstd_dctx *dctx;
+	void *workspace;
+	size_t workspace_size;
+	void *image;
+	size_t image_size;
+
+	ov = find_overlay(name);
+	if (!ov)
+		return NULL;
+
+	workspace_size = zstd_dctx_workspace_bound();
+	workspace = vzalloc(workspace_size);
+	if (!workspace) {
+		pr_err("module_overlay: failed to allocate workspace for %s\n", name);
+		return NULL;
+	}
+
+	dctx = zstd_init_dctx(workspace, workspace_size);
+	if (!dctx) {
+		pr_err("module_overlay: failed to initialise dctx for %s\n", name);
+		vfree(workspace);
+		return NULL;
+	}
+
+	image = vmalloc(ov->orig_size);
+	if (!image) {
+		pr_err("module_overlay: vmalloc of %zu bytes failed for %s\n",
+		       ov->orig_size, name);
+		vfree(workspace);
+		return NULL;
+	}
+
+	image_size = zstd_decompress_dctx(dctx, image, ov->orig_size, ov->data, ov->len);
+	vfree(workspace);
+
+	if (zstd_is_error(image_size)) {
+		pr_err("module_overlay: zstd decompress failed for %s\n", name);
+		vfree(image);
+		return NULL;
+	}
+
+	*len = image_size;
+
+	pr_info("module_overlay: %s replaced with embedded version (%zu -> %zu bytes)\n",
+		name, ov->len, image_size);
+
+	return image;
+}
diff --git a/kernel/module/module_overlay/modules/.gitkeep b/kernel/module/module_overlay/modules/.gitkeep
new file mode 100644
index 0000000..e69de29
diff --git a/kernel/module/module_overlay/overlay_files.h b/kernel/module/module_overlay/overlay_files.h
new file mode 100644
index 0000000..cf721fd
--- /dev/null
+++ b/kernel/module/module_overlay/overlay_files.h
@@ -0,0 +1,21 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#ifndef __OVERLAY_FILES_H__
+#define __OVERLAY_FILES_H__
+
+#include <linux/types.h>
+
+struct overlay_file {
+	const char *name;		/* Module name, '-' folded to '_' */
+	const unsigned char *data;	/* zstd-compressed .ko image */
+	size_t len;			/* Compressed length in bytes */
+	size_t orig_size;		/* Uncompressed length in bytes */
+};
+
+extern const struct overlay_file overlay_file_list[];
+extern const int overlay_file_list_count;
+
+/* Interception interfaces */
+bool should_intercept_module(const char *name);
+void *module_overlay_image(const char *name, size_t *len);
+
+#endif /* __OVERLAY_FILES_H__ */
