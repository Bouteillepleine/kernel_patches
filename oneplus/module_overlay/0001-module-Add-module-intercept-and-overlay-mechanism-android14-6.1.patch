 kernel/module/main.c                          |  64 ++++++++++
 kernel/module/module_overlay/Makefile         |  14 +++
 .../module/module_overlay/convert_overlay.sh  | 117 ++++++++++++++++++
 .../module/module_overlay/module_intercept.c  |  89 +++++++++++++
