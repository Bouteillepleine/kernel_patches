From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Oneplus <Oneplus@oneplus.com>
Date: Tue, 24 Dec 2024 12:51:00 +0100
Subject: [PATCH] nethunter: Add Kali NetHunter kernel configurations

Add comprehensive kernel configuration support for Kali NetHunter:
- Bluetooth devices (USB adapters, virtual HCI)
- Software Defined Radio (AirSpy, HackRF)
- CAN Bus support (automotive hacking)
- USB Serial adapters (CH341, FTDI, PL2303)
- Network enhancements (VSOCKETS, NETLINK_DIAG)

Signed-off-by: Oneplus <Oneplus@oneplus.com>
---
 common/arch/arm64/configs/gki_defconfig | 68 ++++++++++++++++++++++++++
 1 file changed, 68 insertions(+)

diff --git a/common/arch/arm64/configs/gki_defconfig b/common/arch/arm64/configs/gki_defconfig
--- a/common/arch/arm64/configs/gki_defconfig
+++ b/common/arch/arm64/configs/gki_defconfig
@@ -1,3 +1,71 @@
+#
+# Kali NetHunter Configuration
+#
+
+# Bluetooth USB Adapters Support
+CONFIG_BT_HCIBTUSB=y
+CONFIG_BT_HCIBTUSB_BCM=y
+CONFIG_BT_HCIBTUSB_RTL=y
+CONFIG_BT_HCIVHCI=y
+CONFIG_BT_HCIBCM203X=y
+CONFIG_BT_HCIBPA10X=y
+CONFIG_BT_HCIBFUSB=y
+
+# Software Defined Radio (SDR) Support
+CONFIG_USB_AIRSPY=y
+CONFIG_USB_HACKRF=y
+
+# CAN Bus Support (Automotive Hacking)
+CONFIG_CAN=y
+CONFIG_CAN_DEV=y
+CONFIG_CAN_CALC_BITTIMING=y
+CONFIG_CAN_LEDS=y
+CONFIG_CAN_VCAN=y
+
+CONFIG_CAN_GRCAN=y
+CONFIG_CAN_XILINXCAN=y
+
+# Bosch C_CAN/D_CAN devices
+CONFIG_CAN_C_CAN=y
+CONFIG_CAN_C_CAN_PLATFORM=y
+CONFIG_CAN_C_CAN_PCI=y
+
+# Bosch CC770 and Intel AN82527 devices
+CONFIG_CAN_CC770=y
+CONFIG_CAN_CC770_ISA=y
+CONFIG_CAN_CC770_PLATFORM=y
+
+# Bosch M_CAN devices
+CONFIG_CAN_M_CAN=y
+CONFIG_CAN_M_CAN_PCI=y
+CONFIG_CAN_M_CAN_PLATFORM=y
+CONFIG_CAN_M_CAN_TCAN4X5X=y
+
+# CAN SPI interfaces
+CONFIG_CAN_HI311X=y
+CONFIG_CAN_MCP251X=y
+
+# CAN USB interfaces
+CONFIG_CAN_8DEV_USB=y
+CONFIG_CAN_EMS_USB=y
+CONFIG_CAN_ESD_USB2=y
+CONFIG_CAN_GS_USB=y
+CONFIG_CAN_KVASER_USB=y
+CONFIG_CAN_PEAK_USB=y
+
+# Network Enhancements
+CONFIG_NETLINK_DIAG=y
+CONFIG_VSOCKETS=y
+CONFIG_NET_SCHED=y
+CONFIG_NET_EMATCH_CANID=y
+
+# USB Serial Adapters Support
+CONFIG_USB_SERIAL=y
+CONFIG_USB_SERIAL_CONSOLE=y
+CONFIG_USB_SERIAL_GENERIC=y
+CONFIG_USB_SERIAL_CH341=y
+CONFIG_USB_SERIAL_FTDI_SIO=y
+CONFIG_USB_SERIAL_PL2303=y
--
2.47.1
